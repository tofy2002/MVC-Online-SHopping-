@model CheckoutVM
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-4">

    <h2 class="mb-4">Checkout</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="row g-4">

        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Order summary</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.cart.CartItems)
                            {
                                <tr class="align-middle">
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>$@item.Price</td>
                                    <td class="fw-bold">$@(item.Price* item.Quantity)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Total</td>
                                <td class="fw-bold text-success fs-5">$@Model.cart.TotalPrice</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Shipping address</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Checkout" method="post">

                        @if (Model.Addresses == null || !Model.Addresses.Any())
                        {
                            <p class="text-muted">You have no saved addresses. Please add one first.</p>
                        }
                        else
                        {
                            @foreach (var item in Model.Addresses)
                            {
                                <div class="form-check border rounded p-3 mb-2">
                                    <input class="form-check-input"
                                           type="radio"
                                           name="SelectedAddressId"
                                           value="@item.AddressId"
                                           @(item.IsDefault ? "checked" : "") />
                                    <label class="form-check-label ms-2">
                                        <span class="fw-bold">@item.Street</span><br />
                                        <span class="text-muted">@item.City, @item.Country, @item.ZIP</span>
                                        @if (item.IsDefault)
                                        {
                                            <span class="badge bg-success ms-2">Default</span>
                                        }
                                    </label>
                                </div>
                            }
                        }

                        <span asp-validation-for="SelectedAddressId" class="text-danger"></span>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-success flex-grow-1">
                                Place order
                            </button>
                            <a asp-controller="Address"
                               asp-action="Create"
                               class="btn btn-outline-dark">
                                Add address
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}