@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid px-0">

    <div class="bg-dark text-white py-5 mb-5">
        <div class="container text-center py-4">
            <h1 class="display-3 fw-bold mb-3">Welcome to Our Store</h1>
            <p class="fs-5 text-white-50 mb-4">Find the best products at the best prices</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-warning btn-lg px-5">
                Shop now
            </a>
        </div>
    </div>

    <div class="container mb-5">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 p-4">
                    <div class="display-4 mb-3">🛍️</div>
                    <h5 class="fw-bold">Wide selection</h5>
                    <p class="text-muted">Browse hundreds of products across many categories</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 p-4">
                    <div class="display-4 mb-3">🚚</div>
                    <h5 class="fw-bold">Fast delivery</h5>
                    <p class="text-muted">Get your orders delivered quickly to your door</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 p-4">
                    <div class="display-4 mb-3">🔒</div>
                    <h5 class="fw-bold">Secure checkout</h5>
                    <p class="text-muted">Your payment and personal data are always safe</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-light py-5 mb-5">
        <div class="container text-center">
            <h2 class="fw-bold mb-2">Ready to start shopping?</h2>
            <p class="text-muted mb-4">Join thousands of happy customers today</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-dark btn-lg px-4">
                    Browse products
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-dark btn-lg px-4">
                    Create account
                </a>
            </div>
        </div>
    </div>

</div>