@model AddressVM
@{
    ViewData["Title"] = "Delete address";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Delete address</h5>
                </div>
                <div class="card-body text-center py-4">

                    <p class="fs-5 mb-1">Are you sure you want to delete this address?</p>
                    <p class="fw-bold mb-1">@Model.Street</p>
                    <p class="text-muted mb-4">@Model.City, @Model.Country, @Model.ZIP</p>
                    <p class="text-danger small">This action cannot be undone.</p>

                    <form asp-action="Delete" method="post">
                        <input asp-for="AddressId" type="hidden" />
                        <div class="d-flex gap-2 justify-content-center mt-3">
                            <input type="submit" value="Yes, delete" class="btn btn-danger flex-grow-1" />
                            <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>